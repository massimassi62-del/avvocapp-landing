{
  "entities": {
    "Settings": {
      "title": "Site Settings",
      "description": "Global contact and business information for the website.",
      "type": "object",
      "properties": {
        "phone": { "type": "string", "description": "Contact phone number" },
        "email": { "type": "string", "format": "email", "description": "Contact email address" },
        "address": { "type": "string", "description": "Physical address" },
        "city": { "type": "string", "description": "City and province" },
        "vatNumber": { "type": "string", "description": "VAT number (Partita IVA)" },
        "presentationVideoUrl": { "type": "string", "description": "YouTube embed URL for the presentation video" },
        "socials": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" },
            "facebook": { "type": "string" }
          }
        }
      },
      "required": ["phone", "email", "address", "city", "vatNumber", "presentationVideoUrl"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "An article published on the website's blog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["title", "excerpt", "author", "date", "category", "image"]
    },
    "ImageConfig": {
      "title": "Image Configuration",
      "description": "Mapping of UI sections to their respective image URLs.",
      "type": "object",
      "properties": {
        "home": {
          "type": "object",
          "properties": {
            "dashboard": { "type": "string" }
          }
        },
        "blog": {
          "type": "object",
          "properties": {
            "post1": { "type": "string" },
            "post2": { "type": "string" },
            "post3": { "type": "string" }
          }
        }
      }
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "A single user interaction or page view.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["pageview", "click"] },
        "path": { "type": "string" },
        "label": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "sessionId": { "type": "string" }
      },
      "required": ["type", "timestamp", "sessionId"]
    },
    "AnalyticsSession": {
      "title": "Analytics Session",
      "description": "A user session tracking duration and metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" },
        "isNewUser": { "type": "boolean" }
      },
      "required": ["id", "startTime", "lastActive"]
    },
    "AnalyticsSummary": {
      "title": "Analytics Summary",
      "description": "Aggregated analytics data for the dashboard.",
      "type": "object",
      "properties": {
        "totalVisits": { "type": "number" },
        "uniqueVisitors": { "type": "number" },
        "avgSessionDuration": { "type": "number" },
        "demoClicks": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "settings/global": {
      "schema": "Settings",
      "description": "Single document containing all global site settings."
    },
    "blog_posts": {
      "schema": "BlogPost",
      "description": "Collection of blog articles."
    },
    "images/config": {
      "schema": "ImageConfig",
      "description": "Single document containing image URL mappings."
    },
    "analytics_events": {
      "schema": "AnalyticsEvent",
      "description": "Collection of raw analytics events."
    },
    "analytics_sessions": {
      "schema": "AnalyticsSession",
      "description": "Collection of user sessions."
    },
    "analytics_summary/global": {
      "schema": "AnalyticsSummary",
      "description": "Aggregated analytics data."
    }
  }
}
